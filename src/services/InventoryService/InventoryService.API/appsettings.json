{
  "Kestrel": {
    "Endpoints": {
      "HttpApi": {
        "Url": "http://+:8080",
        "Protocols": "Http1"
      },
      "Grpc": {
        "Url": "http://+:8081",
        "Protocols": "Http2"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MongoDb": "mongodb://mongodb:27017/inventory-service?replicaSet=rs0"
  },
  "RedisOptions": {
    "ConnectionString": "redis:6379"
  },
  "MongoDbOptions": {
    "DatabaseName": "inventory-service",
    "InventoryItemsCollectionName": "inventory-items",
    "ReservationsCollectionName": "reservations",
    "InventoryTransactionsCollectionName": "inventory-transactions"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.MongoDB"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "MongoDB.Driver": "Warning",
        "Grpc": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MongoDBBson",
        "Args": {
          "databaseUrl": "mongodb://mongodb:27017/inventory-service?replicaSet=rs0",
          "collectionName": "ApplicationLogs"
        }
      }
    ],
    "Properties": {
      "Application": "InventoryService"
    }
  },
  "AllowedHosts": "*"
}
