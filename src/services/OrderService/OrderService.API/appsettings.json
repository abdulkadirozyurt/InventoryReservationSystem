{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "InventoryService": {
    "Address": "http://inventoryservice-api:8081"
  },
  "InventoryGrpcResilience": {
    "TimeoutSeconds": 3,
    "RetryCount": 3,
    "RetryBaseDelayMilliseconds": 200,
    "CircuitBreakerMinimumThroughput": 5,
    "CircuitBreakerSamplingDurationSeconds": 30,
    "CircuitBreakerFailureRatio": 0.5,
    "CircuitBreakerBreakDurationSeconds": 15
  },
  "MongoDbOptions": {
    "DatabaseName": "order-service",
    "OrdersCollectionName": "orders",
    "OrderHistoryCollectionName": "order-history"
  },
  "ConnectionStrings": {
    "MongoDb": "mongodb://mongodb:27017/order-service?replicaSet=rs0",
    "Redis": "redis:6379"
  },
  "Idempotency": {
    "CompletedTtl": "24:00:00",
    "ProcessingTtl": "00:02:00",
    "ReplayWaitTimeout": "00:00:03",
    "ReplayPollInterval": "00:00:00.100"
  }
}
